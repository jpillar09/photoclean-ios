{
  "expo": {
    "name": "PhotoClean",
    "slug": "photoclean",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a5c3a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.photoclean.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "PhotoClean needs access to your photo library to help you review and clean up photos.",
        "NSPhotoLibraryAddUsageDescription": "PhotoClean needs access to save photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a5c3a",
        "foregroundImage": "./assets/icon.png"
      }
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "PhotoClean needs access to your photo library to help you review and organize your photos.",
          "savePhotosPermission": "Allow PhotoClean to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "photoclean-ios"
      }
    }
  }
}
